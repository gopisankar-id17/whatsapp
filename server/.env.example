# WhatsApp Clone - Server Environment Variables
# Copy this to .env and update values for local development
# For Render deployment, set these in the Render dashboard

# Database Configuration (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS Configuration - Set to your Vercel frontend URL
CLIENT_URL=https://your-vercel-app.vercel.app
ALLOW_ALL_ORIGINS=false

# Port Configuration (Render uses 10000 by default)
PORT=3002
